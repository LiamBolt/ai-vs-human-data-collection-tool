# Database
POSTGRES_USER=aivb
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aivbrain
DATABASE_URL=postgresql+asyncpg://aivb:changeme@db:5432/aivbrain

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_MIN=720

# Break duration in seconds (default 300 = 5 minutes)
BREAK_DURATION_SECONDS=300

# Bootstrap admin account (created on first startup if no staff users exist)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=changeme-admin

# Frontend build var (split hosting only, e.g. Render). Leave UNSET for local/compose,
# where the SPA calls same-origin '/api/v1' via the nginx proxy. For Render, set this on
# the static-site service to the backend's absolute API base:
# VITE_API_BASE_URL=https://aivb-backend.onrender.com/api/v1
